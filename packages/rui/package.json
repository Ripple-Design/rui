{
    "name": "@ripple-design/rui",
    "version": "1.0.20",
    "description": "Modular and customizable Ripple Design UI components for Vue 3",
    "files": [
        "dist",
        "src/styles"
    ],
    "type": "module",
    "sideEffects": [
        "**/*.css",
        "**/*.scss"
    ],
    "main": "dist/es/index.js",
    "module": "dist/es/index.js",
    "types": "dist/types/src/index.d.ts",
    "typesVersions": {
        "*": {
            "": [
                "./dist/types/src/index.d.ts"
            ]
        }
    },
    "exports": {
        ".": {
            "types": "./dist/types/src/index.d.ts",
            "import": "./dist/es/index.js"
        },
        "./styles.css": "./dist/rui.css"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vue-tsc -b --noEmit tsconfig.json && vite build",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.7",
        "sass": "^1.93.2",
        "vite": "^8.0.16",
        "vite-plugin-dts": "^4.5.4"
    },
    "peerDependencies": {
        "vue": "^3.5.0"
    },
    "sass": "./src/styles/index.scss"
}
