---
import BaseLayout from "./BaseLayout.astro"
import type { CollectionEntry } from "astro:content"
import type { OutlineItem } from "../lib/docs"
import { getModeUrl, getReadingMode, getTabsForDoc, groupDocs } from "../lib/docs"

export interface Props {
    entry: CollectionEntry<"docs">
    locale: string
    allDocs: CollectionEntry<"docs">[]
    outline: OutlineItem[]
}

const { entry, locale, allDocs, outline } = Astro.props
const mode = getReadingMode(Astro.url)
const groupedDocs = groupDocs(allDocs, locale, mode)
const tabs = getTabsForDoc(allDocs, locale, entry.data.docSlug)
---

<BaseLayout title={entry.data.title} locale={locale} currentUrl={Astro.url} sectionLabel="Components">
    <style>
        .docs-shell {
            display: grid;
            gap: 1.5rem;
        }

        .docs-sidebar,
        .docs-outline {
            border: 1px solid #d0d0d0;
            padding: 1rem;
        }

        .docs-sidebar nav section + section {
            margin-top: 1rem;
        }

        .docs-sidebar ol,
        .docs-content ul,
        .docs-outline ul {
            margin: 0;
            padding-left: 1.25rem;
        }

        .docs-content header {
            margin-bottom: 1.5rem;
        }

        .docs-content h1 {
            margin-top: 0;
        }

        .docs-mode ul,
        .docs-tabs ul {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .docs-mode,
        .docs-tabs,
        .docs-links {
            margin-top: 1rem;
        }

        .docs-outline ul {
            list-style: none;
            padding-left: 0;
        }

        .docs-outline li + li {
            margin-top: 0.5rem;
        }

        .docs-outline li[data-depth="3"] {
            padding-left: 1rem;
        }

        .docs-outline li[data-depth="4"] {
            padding-left: 2rem;
        }

        @media (min-width: 900px) {
            .docs-shell {
                grid-template-columns: 16rem minmax(0, 1fr) 14rem;
                align-items: start;
            }

            .docs-sidebar,
            .docs-outline {
                position: sticky;
                top: 1rem;
            }
        }
    </style>

    <div class="docs-shell">
        <aside class="docs-sidebar">
            <nav aria-label="Components navigation">
                <h2>Components</h2>
                {groupedDocs.map(({ group, items }) => (
                    <section>
                        <h3>{group}</h3>
                        <ol>
                            {items.map((item) => (
                                <li>
                                    <a href={`/${locale}/${item.data.docSlug}/${item.data.tab}`}>{item.data.title}</a>
                                </li>
                            ))}
                        </ol>
                    </section>
                ))}
            </nav>
        </aside>

        <article class="docs-content">
            <header>
                <h1>{entry.data.title}</h1>
                <!--<p>Current reading mode: {mode}</p>-->
                <!--<nav class="docs-mode" aria-label="Reading mode">-->
                <!--    <ul>-->
                <!--        <li><a href={getModeUrl(Astro.url, "design")} aria-current={mode === "design" ? "true" : undefined}>Design</a></li>-->
                <!--        <li><a href={getModeUrl(Astro.url, "develop")} aria-current={mode === "develop" ? "true" : undefined}>Develop</a></li>-->
                <!--    </ul>-->
                <!--</nav>-->
                <nav class="docs-tabs" aria-label="Page sections">
                    <ul>
                        {tabs.map((tabEntry) => (
                            <li>
                                <a
                                    href={`/${locale}/${tabEntry.data.docSlug}/${tabEntry.data.tab}?mode=${mode}`}
                                    aria-current={tabEntry.data.tab === entry.data.tab ? "page" : undefined}
                                >
                                    {tabEntry.data.tab}
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
                <p class="docs-links">
                    <a href={entry.data.api}>View API</a>
                </p>
            </header>

            <div class="docs-body">
                <slot />
            </div>
        </article>

        <aside class="docs-outline">
            <nav aria-label="Current section outline">
                <h2>On this page</h2>
                <h3>{entry.data.tab}</h3>
                <ul>
                    {outline.length > 0 ? (
                        outline.map((item) => (
                            <li data-depth={item.depth}>
                                <a href={`#${item.slug}`}>{item.text}</a>
                            </li>
                        ))
                    ) : (
                        <li>No subsection headings yet.</li>
                    )}
                </ul>
            </nav>
        </aside>
    </div>
</BaseLayout>
