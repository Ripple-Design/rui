---
import "@ripple-design/rui/styles.css"
import { getDirectionMode, getLocaleUrl, locales } from "../lib/docs"

export interface Props {
    title: string
    locale: string
    currentUrl?: URL
    sectionLabel?: string
}

const { title, locale, currentUrl = Astro.url, sectionLabel = "Components" } = Astro.props
const direction = getDirectionMode(currentUrl)
---

<!doctype html>
<html lang={locale} dir={direction}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
        <style>
            :root {
                color-scheme: light;
                font-family: Arial, sans-serif;
                line-height: 1.5;
            }

            body {
                margin: 0;
            }

            a,
            button {
                color: inherit;
                font: inherit;
            }

            .site-header {
                border-bottom: 1px solid #d0d0d0;
                padding: 1rem;
            }

            .site-header__inner {
                display: grid;
                gap: 1rem;
                align-items: start;
            }

            .site-title {
                margin: 0;
                font-size: 1.25rem;
            }

            .header-nav,
            .header-tools,
            .header-direction {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
            }

            .header-nav ul,
            .header-tools ul,
            .header-direction ul {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .page-shell {
                width: min(1440px, 100% - 2rem);
                margin: 0 auto;
                padding: 1rem 0 2rem;
            }

            @media (min-width: 900px) {
                .site-header__inner {
                    grid-template-columns: 1fr auto auto auto;
                }
            }
        </style>
        <script is:inline>
            const current = new URL(window.location.href)
            const dir = current.searchParams.get("dir") === "rtl"
                ? "rtl"
                : localStorage.getItem("rui-docs-dir") === "rtl"
                  ? "rtl"
                  : "ltr"
            document.documentElement.setAttribute("dir", dir)
            localStorage.setItem("rui-docs-dir", dir)
        </script>
    </head>
    <body>
        <header class="site-header">
            <div class="site-header__inner">
                <p class="site-title">RUI Docs</p>
                <nav class="header-nav" aria-label="Primary">
                    <ul>
                        <li><a href={`/${locale}/getting-started/spec`}>{sectionLabel}</a></li>
                        <li><a href={`/${locale}/api/text-field`}>API</a></li>
                    </ul>
                </nav>
                <nav class="header-tools" aria-label="Language switcher">
                    <ul>
                        {locales.map((item) => (
                            <li>
                                <a href={getLocaleUrl(currentUrl, item)} data-locale-link={item} aria-current={item === locale ? "true" : undefined}>
                                    {item}
                                </a>
                            </li>
                        ))}
                    </ul>
                </nav>
                <nav class="header-direction" aria-label="Direction switcher">
                    <ul>
                        <li>
                            <button type="button" data-dir-toggle="ltr" aria-pressed={direction === "ltr" ? "true" : "false"}>LTR</button>
                        </li>
                        <li>
                            <button type="button" data-dir-toggle="rtl" aria-pressed={direction === "rtl" ? "true" : "false"}>RTL</button>
                        </li>
                    </ul>
                </nav>
            </div>
        </header>
        <main class="page-shell">
            <slot />
        </main>
        <script is:inline>
            const url = new URL(window.location.href)
            const activeDir = document.documentElement.getAttribute("dir") === "rtl" ? "rtl" : "ltr"

            document.querySelectorAll("[data-dir-toggle]").forEach((node) => {
                node.setAttribute("aria-pressed", node.getAttribute("data-dir-toggle") === activeDir ? "true" : "false")
                node.addEventListener("click", () => {
                    const dir = node.getAttribute("data-dir-toggle")
                    if (!dir) return
                    url.searchParams.set("dir", dir)
                    localStorage.setItem("rui-docs-dir", dir)
                    document.documentElement.setAttribute("dir", dir)
                    document.querySelectorAll("[data-dir-toggle]").forEach((button) => {
                        button.setAttribute("aria-pressed", button.getAttribute("data-dir-toggle") === dir ? "true" : "false")
                    })
                    history.replaceState({}, "", `${url.pathname}${url.search}`)
                })
            })

            document.querySelectorAll("[data-locale-link]").forEach((node) => {
                const href = node.getAttribute("href")
                if (!href) return
                const next = new URL(href, window.location.origin)
                if (url.searchParams.has("mode")) {
                    next.searchParams.set("mode", url.searchParams.get("mode") ?? "")
                }
                if (url.searchParams.has("dir")) {
                    next.searchParams.set("dir", url.searchParams.get("dir") ?? "")
                } else if (localStorage.getItem("rui-docs-dir") === "rtl") {
                    next.searchParams.set("dir", "rtl")
                }
                node.setAttribute("href", `${next.pathname}${next.search}`)
            })
        </script>
    </body>
</html>
