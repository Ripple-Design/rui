---
import { getCollection, render } from "astro:content"
import DocsLayout from "../../layouts/DocsLayout.astro"
import { extractOutline, isDocTab, isLocale } from "../../lib/docs"
import { validateApiLocales, validateCrossLinks, validateDocsLocales } from "../../lib/validate-content"

export async function getStaticPaths() {
    const docs = await getCollection("docs")
    const api = await getCollection("api")

    validateDocsLocales(docs)
    validateApiLocales(api)
    validateCrossLinks(docs, api)

    return docs.map((entry) => ({
        params: {
            locale: entry.data.locale,
            slug: `${entry.data.docSlug}/${entry.data.tab}`,
        },
        props: { entry },
    }))
}

const { locale, slug } = Astro.params
const { entry } = Astro.props

if (!locale || !isLocale(locale)) {
    throw new Error("Invalid locale")
}

const slugValue = Array.isArray(slug) ? slug.join("/") : slug ?? ""
const segments = slugValue.split("/")
const tab = segments[segments.length - 1]

if (!isDocTab(tab)) {
    throw new Error("Invalid docs tab")
}

const allDocs = await getCollection("docs")
const rendered = await render(entry)
const outline = extractOutline(rendered)
const { Content } = rendered
---

<DocsLayout entry={entry} locale={locale} allDocs={allDocs} outline={outline}>
    <Content />
</DocsLayout>
