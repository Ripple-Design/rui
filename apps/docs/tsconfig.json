{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "paths": {
            "rui/components": ["../../packages/rui/src/components/index.ts"],
            "rui/components/*": ["../../packages/rui/src/components/*"],
            "rui/styles": ["../../packages/rui/src/styles.ts"]
        },
        "plugins": [
            {
                "name": "@vue/typescript-plugin",
                "location": "node_modules/@vue/language-server",
                "languages": ["vue"]
            }
        ]
    }
}
