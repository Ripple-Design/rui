{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@docs/*": ["./src/*"],
            "@ripple-design/rui": ["../../packages/rui/src/index.ts"],
            "@ripple-design/rui/*": ["../../packages/rui/src/*"]
        },
        "plugins": [
            {
                "name": "@vue/typescript-plugin",
                "location": "node_modules/@vue/language-server",
                "languages": ["vue"]
            }
        ]
    }
}
